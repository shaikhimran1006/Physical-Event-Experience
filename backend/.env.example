# Environment variables for Stadium OS Copilot Backend
# Copy this to .env and fill in your values

GCP_PROJECT_ID=stadium-os-copilot
USE_GCP=false
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# Notes:
# - Local mode: set USE_GCP=false (no keys needed)
# - Cloud Run keyless mode: set USE_GCP=true and attach IAM roles to the Cloud Run service account
# - GOOGLE_APPLICATION_CREDENTIALS is only needed when using a local service-account key file

# Pub/Sub Topics
PUBSUB_CROWD_TOPIC=crowd_events
PUBSUB_QUEUE_TOPIC=queue_events
PUBSUB_INTERVENTIONS_TOPIC=interventions
PUBSUB_NOTIFICATIONS_TOPIC=user_notifications

# BigQuery
BQ_DATASET=stadium_os_analytics

# Firebase
FCM_SERVER_KEY=your-fcm-server-key-here

# Environment
ENVIRONMENT=development

# Write security
WRITE_AUTH_REQUIRED=true
WRITE_API_KEY=replace-with-strong-random-key
WRITE_RATE_LIMIT_PER_MINUTE=120
WRITE_JWT_SECRET=replace-with-long-random-jwt-secret
WRITE_JWT_REQUIRED_ROLES=admin,ops
TOKEN_ISSUER_REQUIRED_ROLES=admin
TOKEN_ISSUER_SUBJECT_ROLES={"dashboard-service":["admin","ops"],"fan-service":["fan"]}

# WebSocket security (Authorization/X-API-Key headers or websocket subprotocol)
WS_AUTH_REQUIRED=true
WS_DASHBOARD_REQUIRED_ROLES=admin,ops
WS_FAN_REQUIRED_ROLES=fan,ops,admin

# Observability
LOG_LEVEL=INFO
READ_CACHE_TTL_SECONDS=1.0
