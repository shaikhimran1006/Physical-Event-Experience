{
  "displayName": "Stadium Backend 5xx Spike",
  "documentation": {
    "content": "Backend 5xx responses exceeded baseline for 5 minutes. Check logs, canary status, and roll back if needed.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "conditions": [
    {
      "displayName": "5xx count > 20 over 5m",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"__BACKEND_SERVICE__\" AND metric.type=\"logging.googleapis.com/user/stadium_backend_5xx_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 20,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "1800s"
  },
  "notificationChannels": [
    "__NOTIFICATION_CHANNEL__"
  ],
  "userLabels": {
    "service": "stadium-backend",
    "severity": "critical"
  }
}
