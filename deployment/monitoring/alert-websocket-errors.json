{
  "displayName": "Stadium WebSocket Broadcast Errors",
  "documentation": {
    "content": "WebSocket broadcast errors are sustained. Verify websocket auth, backend health, and active revision logs.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "conditions": [
    {
      "displayName": "WebSocket errors > 5 over 10m",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"__BACKEND_SERVICE__\" AND metric.type=\"logging.googleapis.com/user/stadium_ws_broadcast_errors\"",
        "aggregations": [
          {
            "alignmentPeriod": "600s",
            "perSeriesAligner": "ALIGN_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 5,
        "duration": "600s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "1800s"
  },
  "notificationChannels": [
    "__NOTIFICATION_CHANNEL__"
  ],
  "userLabels": {
    "service": "stadium-backend",
    "severity": "high"
  }
}
